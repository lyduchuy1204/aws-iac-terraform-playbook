# --- Terraform local cache (KHÔNG commit) ---
.terraform/
.terraform.tfstate.lock.info

# --- State files (NHẠY CẢM, KHÔNG commit) ---
*.tfstate
*.tfstate.*
*.tfstate.backup

# --- Crash log ---
crash.log
crash.*.log

# --- File chứa giá trị nhạy cảm (KHÔNG commit) ---
# *.tfvars có thể chứa password, key, secret => không commit.
# Riêng *.tfvars.example thì NÊN commit (để team biết format).
*.tfvars
*.tfvars.json
!*.tfvars.example

# --- LƯU Ý ---
# .terraform.lock.hcl PHẢI được commit. Không thêm vào đây.
