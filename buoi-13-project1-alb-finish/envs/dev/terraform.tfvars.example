# Copy thành terraform.tfvars, KHÔNG commit.

region  = "ap-southeast-1"
project = "iac-playbook"
env     = "dev"

# Lấy từ output buổi 10 (network)
vpc_id            = "vpc-0123456789abcdef0"
public_subnet_ids = ["subnet-pub-aaaa", "subnet-pub-bbbb"]

# Lấy từ output buổi 11 (compute)
asg_name              = "iac-playbook-dev-asg-xxxxxxxx"
ec2_security_group_id = "sg-0123456789abcdef0"
